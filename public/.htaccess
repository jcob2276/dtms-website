# ============================================
# DTMS szkoleniadtms.pl вҖ” .htaccess
# Konfiguracja Apache dla Next.js Static Export
# ============================================

Options -Indexes
ServerSignature Off

# вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”
# 1. HTTPS вҖ” Wymuszenie SSL
# вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Wymuszenie HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  # Wymuszenie www (lub bez www вҖ” wybierz jedno)
  # UsuЕ„ WWW:
  RewriteCond %{HTTP_HOST} ^www\.szkoleniadtms\.pl [NC]
  RewriteRule ^(.*)$ https://szkoleniadtms.pl/$1 [R=301,L]
</IfModule>

# вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”
# 2. PRZEKIEROWANIA LEGACY вҖ” Stare URL-e React SPA
# вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Stary format z ?lang=en вҶ’ nowe ЕӣcieЕјki
  RewriteCond %{QUERY_STRING} ^lang=en$
  RewriteRule ^$ /en? [R=301,L]

  RewriteCond %{QUERY_STRING} ^lang=ua$
  RewriteRule ^$ /ua? [R=301,L]

  # Stara strona bez /pl/ prefix вҶ’ /pl/
  RewriteRule ^uslugi/?$ /pl/uslugi [R=301,L]
  RewriteRule ^polityka-prywatnosci/?$ /pl/polityka-prywatnosci [R=301,L]
  RewriteRule ^kursy-udt-krosno/?$ /pl/kursy-udt-krosno [R=301,L]
  RewriteRule ^kursy-udt-jaslo/?$ /pl/kursy-udt-jaslo [R=301,L]
  RewriteRule ^kursy-udt-sanok/?$ /pl/kursy-udt-sanok [R=301,L]
  RewriteRule ^kursy-udt-rzeszow/?$ /pl/kursy-udt-rzeszow [R=301,L]
  RewriteRule ^kursy-udt-gorlice/?$ /pl/kursy-udt-gorlice [R=301,L]
  RewriteRule ^kursy-udt-brzozow/?$ /pl/kursy-udt-brzozow [R=301,L]
</IfModule>

# вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”
# 3. NEXT.JS STATIC EXPORT вҖ” Routing
# вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Strona gЕӮГіwna вҶ’ /pl/
  RewriteRule ^$ /pl/ [R=301,L]

  # Next.js RSC вҖ” klient ЕјД…da pЕӮaskiej ЕӣcieЕјki, export generuje zagnieЕјdЕјone foldery
  RewriteRule ^(.*/?)__next\.\$d\$locale\.\__PAGE__\.txt$ $1__next.$d$locale/__PAGE__.txt [L]
  RewriteRule ^(.*/?)__next\.\$d\$locale\.\$d\$slug\.\__PAGE__\.txt$ $1__next.$d$locale/$d$slug/__PAGE__.txt [L]
  RewriteRule ^(.*/?)__next\.\$d\$locale\.\$d\$slug\.txt$ $1__next.$d$locale/$d$slug.txt [L]

  # Serwuj istniejД…ce pliki statyczne bezpoЕӣrednio
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Next.js вҖ” routing do pliku HTML (trailing slash support)
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+)/?$ $1.html [L]

  # Nieznane ЕӣcieЕјki poza /pl, /en, /ua вҶ’ 301 na /pl/ (zmiana URL w pasku)
  RewriteCond %{REQUEST_URI} !^/(pl|en|ua|obrazy|_next)(/|$) [NC]
  RewriteCond %{REQUEST_URI} !^/(favicon\.ico|robots\.txt|sitemap\.xml|manifest\.json|sw\.js|404\.html)$ [NC]
  RewriteRule ^ /pl/ [R=301,L]
</IfModule>

# вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”
# 4. CACHE вҖ” NagЕӮГіwki wydajnoЕӣci
# вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”
<IfModule mod_expires.c>
  ExpiresActive On

  # Obrazy вҖ” 1 rok
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"

  # Skrypty i style вҖ” 1 miesiД…c
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/javascript "access plus 1 month"

  # HTML вҖ” brak cache (Next.js zarzД…dza wersjami)
  ExpiresByType text/html "access plus 0 seconds"

  # Czcionki вҖ” 1 rok
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType application/font-woff "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"
</IfModule>

# вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”
# 5. GZIP вҖ” Kompresja
# вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE text/javascript
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE font/woff2
</IfModule>

# вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”
# 6. BEZPIECZEЕғSTWO вҖ” NagЕӮГіwki HTTP
# вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”
<IfModule mod_headers.c>
  # Ochrona przed clickjacking
  Header always set X-Frame-Options "SAMEORIGIN"

  # Ochrona przed XSS
  Header always set X-XSS-Protection "1; mode=block"

  # WymuЕӣ HTTPS (HSTS) вҖ” 1 rok
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

  # Zapobiegaj MIME sniffing
  Header always set X-Content-Type-Options "nosniff"

  # Referrer Policy
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Permissions Policy
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”
# 7. BЕҒДҳDY вҖ” Strony bЕӮДҷdГіw
# вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”
ErrorDocument 404 /404.html
ErrorDocument 500 /404.html
