<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # 1. Wymuszanie HTTPS (bezpieczeństwo i SEO)
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # 2. Usuwanie trailingslash (opcjonalnie, dla spójności URL)
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.*)/$ /$1 [L,R=301]

  # 3. Przekierowanie starych linków AMP (z WordPressa) na główną
  RewriteRule ^amp(/.*)?$ / [L,R=301]

  # 4. Fallback dla React Router (SPA)
  # Jeśli ścieżka nie jest fizycznym plikiem ani folderem, kieruj na index.html
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

# 4. Optymalizacja wydajności (Kompresja Gzip)
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# 5. Cache-Control (SEO i szybkość)
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 1 month"
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
</IfModule>
